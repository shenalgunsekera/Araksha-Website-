# ── Firebase (same project as the Araksha staff app) ──────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_ARAKSHA_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_ARAKSHA_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_WITH_ARAKSHA_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_ARAKSHA_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_WITH_APP_ID

# ── EmailJS (reuse service + public key; NEW template for the customer confirm) ─
NEXT_PUBLIC_EMAILJS_SERVICE_ID=REPLACE_WITH_EMAILJS_SERVICE_ID
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=REPLACE_WITH_EMAILJS_PUBLIC_KEY
NEXT_PUBLIC_EMAILJS_CONFIRM_TEMPLATE_ID=REPLACE_WITH_EMAILJS_CONFIRM_TEMPLATE_ID

# Synthetic-email domain used to map a phone number to a Firebase email/password account
NEXT_PUBLIC_CUSTOMER_EMAIL_DOMAIN=customers.araksha.lk
